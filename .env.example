# ---------------------------------------------------------------------------
# Database — any Postgres provider works (Neon, Supabase, Railway, RDS, local).
# Use a pooled connection URL in production.
# Quick local setup: `docker compose up -d` matches the URL below.
# ---------------------------------------------------------------------------
DATABASE_URL="postgres://saas:saas@localhost:5432/saas_starter"

# ---------------------------------------------------------------------------
# Better Auth — required.
# Generate the secret with: openssl rand -base64 32
# BETTER_AUTH_URL is optional in dev (inferred from request); pin it in prod.
# ---------------------------------------------------------------------------
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL=""

# ---------------------------------------------------------------------------
# Google OAuth — optional. The Google sign-in button is hidden when unset.
# Authorized redirect URI for Google Cloud Console:
#   https://YOUR_HOST/api/auth/callback/google
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------------------------------------------------------------------------
# AI — optional. The /chat example uses Vercel AI Gateway by default so any
# provider works through one key. Override the model in src/app/api/chat/route.ts.
# Get a key: https://vercel.com/dashboard → AI Gateway
# ---------------------------------------------------------------------------
AI_GATEWAY_API_KEY=""
