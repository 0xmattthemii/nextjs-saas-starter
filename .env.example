# ---------------------------------------------------------------------------
# Database — any Postgres provider works (Neon, Supabase, Railway, RDS, local).
# Use a pooled connection URL in production.
# Quick local setup: `docker compose up -d` matches the URL below.
# ---------------------------------------------------------------------------
DATABASE_URL="postgres://saas:saas@localhost:5432/saas_starter"

# ---------------------------------------------------------------------------
# Better Auth — required.
# Generate the secret with: openssl rand -base64 32
# BETTER_AUTH_URL is optional in dev (inferred from request); pin it in prod.
# ---------------------------------------------------------------------------
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL=""

# ---------------------------------------------------------------------------
# Google OAuth — optional. The Google sign-in button is hidden when unset.
# Authorized redirect URI for Google Cloud Console:
#   https://YOUR_HOST/api/auth/callback/google
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------------------------------------------------------------------------
# AI — optional. The /chat example uses the open-source AI SDK with the
# Anthropic provider directly (no gateway, no vendor lock-in).
# Get a key: https://console.anthropic.com/settings/keys
# To use another provider, install its package (e.g. @ai-sdk/openai) and swap
# the import in src/app/api/chat/route.ts — then set that provider's key here.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=""

# ---------------------------------------------------------------------------
# Email — optional. Password reset + org invites are sent via Resend.
# Without RESEND_API_KEY, those emails are logged to the server console (dev).
# Get a key: https://resend.com/api-keys
# EMAIL_FROM must use a domain you've verified in Resend for production;
# "onboarding@resend.dev" works for testing (only delivers to your own address).
# ---------------------------------------------------------------------------
RESEND_API_KEY=""
EMAIL_FROM="SaaS Starter <onboarding@resend.dev>"
